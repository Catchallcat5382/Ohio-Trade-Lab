name = "ohio-trade-lab-pages"
compatibility_date = "2026-07-18"
pages_build_output_dir = "dist"

[[d1_databases]]
binding = "DB"
database_name = "ohio-trade-lab"
database_id = "YOUR_D1_DATABASE_ID"

[vars]
GOOGLE_CLIENT_ID = ""
DISCORD_CLIENT_ID = ""
DISCORD_REDIRECT_URI = "https://YOUR-DOMAIN.pages.dev/api/auth/discord/callback"
PUBLIC_SITE_URL = "https://YOUR-DOMAIN.pages.dev"
# Add these as encrypted secrets in Cloudflare:
# SESSION_SECRET
# DISCORD_CLIENT_SECRET
